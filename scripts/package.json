{
  "name": "genspark-automation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Playwright automation for Genspark document generation",
  "scripts": {
    "genspark": "node genspark-automation.mjs",
    "genspark:slides": "node genspark-automation.mjs --type slides",
    "genspark:docs": "node genspark-automation.mjs --type docs",
    "genspark:all": "node genspark-automation.mjs --type all",
    "install-browser": "npx playwright install chromium"
  },
  "dependencies": {
    "playwright": "^1.50.0"
  }
}
